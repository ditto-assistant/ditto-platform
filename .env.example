# Local dev environment template. Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored; this template is committed.
#
# DEPLOYED HOSTS (GCP app VMs) do NOT use this file directly — their `.env` is
# rendered by the infra repo's `platform_app` Ansible role from GCP Secret
# Manager + Terraform outputs. The notable prod differences are:
#   DITTO_COMPOSE_SERVICES=pylon                 # Postgres = dedicated VM, blobs = GCS
#     (append `embedder` here to co-locate the code-embedding TEI service on the app VM)
#   POSTGRES_HOST=<ditto-pg-platform private IP> # not localhost
#   STORAGE_ENDPOINT_URL=https://storage.googleapis.com  # GCS S3-interop
#   STORAGE_USE_TLS=true
#   STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY      # GCS HMAC key (id / secret)
#   STORAGE_REGION=auto
# and DITTO_UPLOAD_PAYMENT_ADDRESS is injected at deploy time from the
# ditto-platform repo's GitHub environment secret (see .github/workflows/deploy.yml),
# not from Secret Manager. Locally you still set it below.


# --- API server ---

# Interface to bind. ``0.0.0.0`` inside containers; ``127.0.0.1`` to
# restrict to the loopback in local dev.
API_HOST=0.0.0.0

# TCP port the FastAPI app listens on. Host port 8001 is reserved for
# Pylon so 8000 is the default API slot.
API_PORT=8000

# Root logger level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
API_LOG_LEVEL=INFO


# --- Public dashboard (transparency front door) ---

# Serve the static dashboard SPA (dashboard/index.html) same-origin at `/`, so
# its /api/v1/public/* calls need no CORS. Set false to run API-only.
DITTO_DASHBOARD_ENABLED=true

# Public wandb project URL injected into the served dashboard's "full telemetry"
# link. Point at the public validator project once it exists, e.g.
# https://wandb.ai/<entity>/ditto-sn118
DITTO_DASHBOARD_WANDB_URL=https://wandb.ai/

# Optional validator-name decoration. Taostats documents free API keys, but its
# validator endpoint rejects anonymous requests. Leave both values unset for the
# hotkey-only fallback, or provision a free key and set the documented SN118 URL.
# The dashboard must not scrape taostats.io or require a paid plan. Refreshes run
# in the background; public fleet requests never wait on the external service.
# DITTO_TAOSTATS_VALIDATOR_NAMES_URL=https://api.taostats.io/api/dtao/validator/available/v1?netuid=118
# DITTO_TAOSTATS_API_KEY=<free-taostats-api-key>
# DITTO_TAOSTATS_TIMEOUT_SECONDS=1.5
# DITTO_TAOSTATS_REFRESH_SECONDS=3600
# DITTO_TAOSTATS_RETRY_SECONDS=300
# DITTO_TAOSTATS_MAX_STALE_SECONDS=86400


# --- Pylon ---

# HTTP URL of the local Pylon container (see docker-compose.yml). Pylon
# is exposed on host port 8001 because the API server owns 8000.
PYLON_URL=http://localhost:8001

# Open-access token for read endpoints (neurons, blocks, extrinsics).
# Used by the API server and the smoke script. Any string Pylon was
# started with; not a secret in local dev.
PYLON_OPEN_ACCESS_TOKEN=dev-open-access

# Identity credentials. Required only for write endpoints (put_weights).
# Leave blank for read-only / smoke usage. The validator daemon needs both.
PYLON_IDENTITY_NAME=
PYLON_IDENTITY_TOKEN=

# --- Pylon write identity (server side of the token above) ---
# Pylon signs set_weights itself from a mounted wallet, so the "credential"
# is just a self-generated bearer token (NOT issued by anyone):
#     openssl rand -base64 32
# Put that value in PYLON_TOKEN here AND in the validator's
# PYLON_IDENTITY_TOKEN; they must match. PYLON_IDENTITIES lists the identity
# names Pylon will serve (empty [] = read-only Pylon). The wallet named below
# must exist under BITTENSOR_WALLET_PATH and be mounted into the container.
PYLON_TOKEN=
PYLON_IDENTITIES=["validator"]
PYLON_ID_VALIDATOR_WALLET_NAME=validator
PYLON_ID_VALIDATOR_HOTKEY_NAME=default
# Host path to the bittensor wallet dir mounted read-only into Pylon.
# MUST be absolute — Docker does not expand "~". Defaults to $HOME/.bittensor/wallets.
BITTENSOR_WALLET_PATH=/home/you/.bittensor/wallets


# --- Subnet ---

# Bittensor subnet netuid the codebase operates on.
NETUID=118

# Subtensor network the substrate-interface reader connects to for the
# Pylon events gap. One of: finney (mainnet), test (testnet), local, or
# a full wss:// URL.
SUBTENSOR_NETWORK=finney


# --- Postgres ---

# Connection details for the local docker-compose Postgres. Dev defaults
# match the service in docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ditto
POSTGRES_PASSWORD=ditto
POSTGRES_DB=ditto

# Pool sizing + per-command timeout. Tune in production for steady-state load.
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT=30.0


# --- Upload + pricing ---

# Ditto-controlled SS58 address that receives upload fees. Required at
# boot - the API server validates the value as a real SS58 string and
# refuses to start otherwise, so the literal below is intentionally
# broken to force operators to replace it before any real-money flow.
DITTO_UPLOAD_PAYMENT_ADDRESS=REPLACE_WITH_DITTO_SS58_ADDRESS

# Upload fee in USD. Converted to TAO via the CoinGecko oracle at quote
# time. Multiplied by DITTO_UPLOAD_FEE_BUFFER to absorb TAO price drift
# between the /upload/eval-pricing quote and the on-chain payment.
DITTO_UPLOAD_FEE_USD=5
DITTO_UPLOAD_FEE_BUFFER=1.4

# Optional override. Competition launch default in code is 20 MiB; operators may
# tune this explicitly for local/dev practice or emergency rollout changes.
# DITTO_MAX_TARBALL_SIZE_BYTES=20971520

# Local/dev only: bypass the on-chain validator_permit gate for validator HTTP
# endpoints. Signatures still verify; this only skips permit authorization.
# DITTO_DEV_ALLOW_UNPERMITTED_VALIDATOR=1

# --- Platform-operated screener auth ---

# Both values are required to enable /screener/* endpoints. Use the public
# hotkey of the dedicated, no-funds screener wallet; it does not need an
# on-chain validator permit. Generate and store the token as a secret, for
# example with: openssl rand -base64 32
# SCREENER_HOTKEY=<dedicated-screener-hotkey>
# SCREENER_API_TOKEN=<random-token-at-least-32-characters>
# DITTO_ADMIN_API_TOKEN=<separate-random-token-at-least-32-characters>

# In-process pricing cache (seconds). CoinGecko has hourly granularity
# and rate limits, so we cache per process for an hour by default.
PRICING_CACHE_TTL_SECONDS=3600

# Hard cap on stale-while-revalidate. If CoinGecko has been unreachable
# for longer than this, /upload/eval-pricing returns 503 rather than
# quoting a stale price.
PRICING_MAX_STALE_SECONDS=86400

# Per-attempt CoinGecko HTTP timeout. Tenacity retries 3 attempts total.
PRICING_COINGECKO_TIMEOUT_SECONDS=5.0

# Operator kill switch. When set, the oracle returns this value verbatim
# and skips CoinGecko + cache entirely. Use during CoinGecko outages or
# if a market-data anomaly needs the fee held at a known value.
# TAO_PRICE_OVERRIDE_USD=


# --- Object storage (S3 / minio) ---

# S3 endpoint URL the API server reads/writes through. Defaults to the
# local minio service in docker-compose.yml. In prod, point at the
# real S3 / R2 / B2 endpoint.
STORAGE_ENDPOINT_URL=http://localhost:9000

# Bucket name where agent tarballs land. minio-create-bucket creates
# this on first ``docker compose up``.
STORAGE_BUCKET=ditto-agents

# Access credentials. minio defaults in dev compose; replace with real
# IAM credentials in prod.
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=miniominio

# Region the client should advertise. minio ignores; AWS S3 requires.
STORAGE_REGION=us-east-1

# Whether to speak TLS against the endpoint. False for local minio,
# true for prod against AWS S3 / R2.
STORAGE_USE_TLS=false

# Optional host overrides for the minio container in docker-compose.
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=miniominio


# --- code-embedding (anti-copy semantic tier) ---
# The code-embedding signal embeds each uploaded crate through a self-hosted
# text-embeddings-inference (TEI) service. See docs/code-embedder.md. DISABLED by
# default: with CODE_EMBEDDER_URL unset the platform embeds nothing (null column,
# no behavior change), so this whole section is optional.

# Base URL of the embedder. Unset = disabled. To enable locally, start the service
# (`make embedder-up`) and point at it. If the API runs on the host, that is the
# published host port; if the API runs inside the compose network, use
# http://embedder:80.
# CODE_EMBEDDER_URL=http://localhost:8080

# Model id STORED with each vector for provenance / re-embed sweeps. Must match the
# model the TEI service actually serves (CODE_EMBEDDER_MODEL_ID below). Required when
# the URL is set.
# CODE_EMBEDDER_MODEL=jinaai/jina-embeddings-v2-base-code

# Model revision pin recorded in the provenance tag (default: main).
# CODE_EMBEDDER_REVISION=main

# Optional Matryoshka output dimension (Qwen3-Embedding supports 32-1024). Unset =
# the model's native width. 256 is ample for near-neighbor moderation and shrinks
# storage + cosine cost.
# CODE_EMBEDDER_DIM=256

# Per-call HTTP timeout (seconds). Best-effort: a slow embedder degrades to a null
# vector rather than stalling the upload. Local TEI is fast (5s is plenty); for a
# scale-to-zero Cloud Run backend raise it (e.g. 30) so a cold start can complete.
# CODE_EMBEDDER_TIMEOUT_SECONDS=5.0

# How the client authenticates to the service: `none` for a local/unauthenticated
# TEI, or `gcp_id_token` for a private Cloud Run service (the client mints a
# Google-signed identity token from the metadata server, audience = the URL).
# CODE_EMBEDDER_AUTH=none

# --- embedder container knobs (docker-compose `embedder` service) ---
# Model the TEI container downloads and serves. Default is the CPU-cheap, Rust-aware
# fallback; set Qwen/Qwen3-Embedding-0.6B for the primary model.
# CODE_EMBEDDER_MODEL_ID=jinaai/jina-embeddings-v2-base-code
# Host port the container publishes (maps to TEI's internal port 80).
# CODE_EMBEDDER_HOST_PORT=8080
